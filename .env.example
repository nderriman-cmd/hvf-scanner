# ── HVF Scanner — Environment Variables ──────────────────────────────────────
# Copy this to .env and fill in your two Telegram values.
# No exchange API keys needed — all market data is free via Yahoo Finance.

# ── Telegram ──────────────────────────────────────────────────────────────────
# Step 1: Message @BotFather on Telegram → /newbot → copy the token below
# Step 2: Send any message to your new bot, then open this URL in a browser:
#         https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#         Copy the "id" value inside "chat" — that is your TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
